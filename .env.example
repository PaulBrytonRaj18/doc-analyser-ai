# ============================================================
# AI-Powered Document Analysis & Extraction — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Anthropic Claude API Key (Required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# API Key for protecting your endpoint (Required for production)
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-strong-random-api-key-here

# Server configuration
PORT=8000
LOG_LEVEL=INFO

# Optional: Environment label
ENVIRONMENT=production
